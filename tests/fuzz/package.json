{
  "name": "rustywind-fuzz-test",
  "version": "1.0.0",
  "description": "Fuzz testing RustyWind against Prettier's Tailwind plugin",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npm run test:fuzz && npm run test:patterns && npm run test:real-world",
    "test:fuzz": "node compare.js",
    "test:patterns": "node compare-real-world-patterns.js",
    "test:real-world": "node test-real-world-classes.mjs",
    "test:with-legacy": "FILTER_LEGACY=false node compare.js"
  },
  "dependencies": {
    "prettier": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "seedrandom": "^3.0.5"
  }
}
